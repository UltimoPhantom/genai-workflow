# ─── Postgres ──────────────────────────────────────────────────────────────
POSTGRES_USER=genai
POSTGRES_PASSWORD=genai_secret
POSTGRES_DB=genai_pipeline
DATABASE_URL=postgresql://genai:genai_secret@postgres:5432/genai_pipeline

# ─── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── RabbitMQ ──────────────────────────────────────────────────────────────
RABBITMQ_USER=genai
RABBITMQ_PASS=genai_secret
RABBITMQ_URL=amqp://genai:genai_secret@rabbitmq:5672/

# ─── MinIO ─────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=genai-pipeline
MINIO_USE_SSL=false

# ─── Pipeline knobs ────────────────────────────────────────────────────────
PARSE_FAIL_RATE=0.15          # 15% simulated 500 in parse stage
TTS_MAX_CONCURRENCY=3         # global vendor concurrency cap
TTS_SIMULATE_SECONDS=2        # sleep duration per TTS chunk
LEASE_SECONDS=60              # task lock lease duration
MAX_RETRIES=3                 # before routing to DLQ
BACKOFF_MS=1000,4000,16000    # per-attempt delay (tiered queues)
WORKER_PREFETCH=4
POISON_TOKEN=POISON           # manuscript containing this string → poison pill
